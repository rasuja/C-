@page
@model IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Todoアプリ - Bootstrap";
}

<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap CSSの読み込み -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .task-done {
            text-decoration: line-through;
            color: #6c757d;
        }
    </style>
</head>

<body>
    <div class="container mt-5" style="max-width: 600px;">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white py-3">
                <h1 class="h4 mb-0">📝 Todoアプリ (Bootstrap版)</h1>
            </div>

            <div class="card-body p-4">
                <p class="text-muted mb-4">現在のタスク数：<span class="badge bg-secondary">@Model.TodoList.Count</span></p>

                <!-- タスク追加フォーム -->
                <form method="post" asp-page-handler="Add" class="input-group mb-4">
                    <input type="text" name="taskname" class="form-control" placeholder="新しいタスクを入力..." required>
                    <button class="btn btn-primary" type="submit">追加</button>
                </form>

                <!-- タスクリスト -->
                <ul class="list-group list-group-flush">
                    @foreach (var t in Model.TodoList)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                            <div class="d-flex align-items-center">
                                <span class="me-3 fs-5">@(t.IsDone ? "✅" : "⭕")</span>
                                <span class="@(t.IsDone ? "task-done" : "fw-bold")">@t.Name</span>
                            </div>

                            <div class="d-flex gap-2">
                                @if (!t.IsDone)
                                {
                                    <form method="post" asp-page-handler="Done" style="margin:0;">
                                        <input type="hidden" name="id" value="@t.Id">
                                        <button type="submit" class="btn btn-sm btn-outline-success">完了</button>
                                    </form>
                                }
                                <form method="post" asp-page-handler="Delete" style="margin:0;">
                                    <input type="hidden" name="id" value="@t.Id">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">削除</button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</body>

</html>