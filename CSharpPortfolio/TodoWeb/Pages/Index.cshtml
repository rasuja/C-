@page
@model IndexModel
@using TodoWeb.Models
@using TodoWeb.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Todoアプリ - ポートフォリオ版";

    // 優先度に応じたバッジのクラスとラベルを取得するヘルパー関数（簡易版）
    string GetPriorityBadgeClass(int priority) => priority switch
    {
        1 => "bg-danger", // 高
        2 => "bg-warning text-dark", // 中
        3 => "bg-info text-dark", // 低
        _ => "bg-secondary"
    };

    string GetPriorityLabel(int priority) => priority switch
    {
        1 => "高",
        2 => "中",
        3 => "低",
        _ => "不明"
    };
}

<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap CSSの読み込み -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f0f2f5;
            font-family: 'Helvetica Neue', Arial, sans-serif;
        }

        .task-card {
            transition: transform 0.2s;
        }

        .task-card:hover {
            transform: translateY(-2px);
        }

        .task-done {
            text-decoration: line-through;
            color: #adb5bd;
        }

        .priority-dot {
            height: 10px;
            width: 10px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
        }
    </style>
</head>

<body>
    <div class="container mt-5" style="max-width: 700px;">
        <div class="text-center mb-4">
            <h1 class="display-6 fw-bold">My Portfolio ToDo</h1>
            <p class="text-muted">C# & ASP.NET Core 学習の成果物</p>
        </div>

        <div class="card shadow border-0 overflow-hidden">
            <div class="card-header bg-dark text-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0"><i class="bi bi-list-check me-2"></i>タスク一覧</h2>
                    <span class="badge bg-light text-dark">残り: @Model.TodoList.Count(t => !t.IsDone) / 合計:
                        @Model.TodoList.Count</span>
                </div>
            </div>

            <div class="card-body p-4">
                <!-- タスク追加フォーム -->
                <form method="post" asp-page-handler="Add" class="card bg-light border-0 mb-4 shadow-sm">
                    <div class="card-body p-3">
                        <div class="row g-2">
                            <div class="col-12 col-md-5">
                                <label class="form-label small text-muted mb-1">タスク名 <span class="text-danger">*</span></label>
                                <input type="text" name="taskname" class="form-control" placeholder="新しいタスクを入力..." required>
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="form-label small text-muted mb-1">期限 (任意)</label>
                                <input type="date" name="dueDate" class="form-control">
                            </div>
                            <div class="col-6 col-md-4">
                                <label class="form-label small text-muted mb-1">優先度</label>
                                <div class="d-flex gap-2">
                                    <select name="priority" class="form-select">
                                        <option value="1">高</option>
                                        <option value="2" selected>中</option>
                                        <option value="3">低</option>
                                    </select>
                                    <button class="btn btn-primary px-3 shadow-sm flex-shrink-0" type="submit">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>

                <hr class="my-4">

                <!-- 未完了タスクリスト -->
                <h3 class="h6 mb-3 fw-bold text-secondary border-bottom pb-2">未完了のタスク</h3>
                <div class="list-group list-group-flush mb-4" style="max-height: 40vh; overflow-y: auto; overflow-x: hidden;">
                    @if (!Model.TodoList.Any(t => !t.IsDone))
                    {
                        <div class="text-center py-4 bg-light rounded">
                            <i class="bi bi-emoji-sunglasses text-muted" style="font-size: 2.5rem;"></i>
                            <p class="mt-2 text-muted mb-0">未完了のタスクはありません！</p>
                        </div>
                    }

                    @foreach (var t in Model.TodoList.Where(t => !t.IsDone))
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-bottom task-card">
                            <div class="d-flex align-items-center flex-grow-1">
                                <div class="me-3">
                                    <form method="post" asp-page-handler="Done" style="margin:0;">
                                        <input type="hidden" name="id" value="@t.Id">
                                        <button type="submit" class="btn btn-link p-0 text-decoration-none" title="完了にする">
                                            <i class="bi bi-circle text-muted fs-4"></i>
                                        </button>
                                    </form>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="badge @GetPriorityBadgeClass(t.Priority)">
                                            @GetPriorityLabel(t.Priority)
                                        </span>
                                        @if (t.DueDate.HasValue)
                                        {
                                            <span class="badge bg-light text-dark border @(t.DueDate.Value < DateTime.Now.Date ? "border-danger text-danger" : "")">
                                                <i class="bi bi-calendar-event me-1"></i>
                                                @t.DueDate.Value.ToString("yyyy/MM/dd")
                                                @(t.DueDate.Value < DateTime.Now.Date ? " (期限切れ)" : "")
                                            </span>
                                        }
                                    </div>
                                    <div class="fw-bold">@t.Name</div>
                                </div>
                            </div>

                            <div class="ms-3 pe-2">
                                <form method="post" asp-page-handler="Delete" style="margin:0;">
                                    <input type="hidden" name="id" value="@t.Id">
                                    <button type="submit" class="btn btn-sm btn-light text-danger border-0" title="削除">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                <!-- 完了済みタスクリスト (折りたたみ) -->
                @if (Model.TodoList.Any(t => t.IsDone))
                {
                    <div class="mt-4">
                        <button class="btn btn-outline-secondary w-100 d-flex justify-content-between align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#completedTasks" aria-expanded="false" aria-controls="completedTasks">
                            <span><i class="bi bi-check2-all me-2"></i>完了したタスク (@Model.TodoList.Count(t => t.IsDone))</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>
                        
                        <div class="collapse mt-2" id="completedTasks">
                            <div class="list-group list-group-flush opacity-75" style="max-height: 25vh; overflow-y: auto; overflow-x: hidden;">
                                @foreach (var t in Model.TodoList.Where(t => t.IsDone))
                                {
                                    <div
                                        class="list-group-item d-flex justify-content-between align-items-center px-0 py-2 border-bottom bg-light">
                                        <div class="d-flex align-items-center flex-grow-1">
                                            <div class="me-3">
                                                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                            </div>
                                            <div class="flex-grow-1">
                                                <span class="badge @GetPriorityBadgeClass(t.Priority) mb-1 opacity-75">
                                                    @GetPriorityLabel(t.Priority)
                                                </span>
                                                <div class="task-done small">@t.Name</div>
                                            </div>
                                        </div>

                                        <div class="ms-3 pe-2">
                                            <form method="post" asp-page-handler="Delete" style="margin:0;">
                                                <input type="hidden" name="id" value="@t.Id">
                                                <button type="submit" class="btn btn-sm btn-light text-danger border-0 py-0">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="text-center mt-4">
            <small class="text-muted">© 2026 C# Portfolio - TodoWeb v1.1</small>
        </div>
    </div>

    <!-- Bootstrap JS の読み込み -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
