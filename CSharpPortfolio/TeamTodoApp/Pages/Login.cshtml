@page
@model LoginModel
@{
    ViewData["Title"] = "ログイン";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            
            @if (Model.IsRegistered)
            {
                <div class="alert alert-success">アカウントの作成が完了しました。ログインしてください。</div>
            }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <div class="card shadow">
                <div class="card-body p-4">
                    <h3 class="text-center mb-4">ログイン</h3>
                    
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">ユーザーID</label>
                            <input type="text" name="Username" class="form-control" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">パスワード</label>
                            <input type="password" name="Password" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2">ログイン</button>
                    </form>
                    
                    <div class="text-center mt-3">
                        <p>アカウントをお持ちでないですか？ <a asp-page="/Signup">新規登録へ</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
