@page
@model IndexModel
@{
    ViewData["Title"] = "Team ToDo カンバンボード";
    
    // ステータス別にタスクを分類
    var todoItems = Model.Tasks.Where(t => t.Status == "ToDo").ToList();
    var inProgressItems = Model.Tasks.Where(t => t.Status == "InProgress").ToList();
    var reviewItems = Model.Tasks.Where(t => t.Status == "Review").ToList();
    var doneItems = Model.Tasks.Where(t => t.Status == "Done").ToList();

    // 担当者（役割）リストの定義
    var assigneeOptions = new List<string> {
        "佐藤（PM）", "鈴木（リーダー）", "高橋（メンバー）", "田中（メンバー）"
    };

    // 役割からバッジの色を決定するローカル関数
    string GetRoleBadgeColor(string role)
    {
        return role switch {
            "PM" => "bg-danger",
            "リーダー" => "bg-warning text-dark",
            "メンバー" => "bg-info text-dark",
            _ => "bg-secondary"
        };
    }
}

<div class="container-fluid py-4">
    <h2 class="mb-4 fw-bold">🚀 チーム開発カンバンボード</h2>

    <!-- タスク追加フォーム -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title">📝 新規タスク作成</h5>
            <form method="post" asp-page-handler="Add" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">タスク名</label>
                    <input type="text" name="Title" class="form-control" required placeholder="実装するタスクを入力...">
                </div>
                <div class="col-md-3">
                    <label class="form-label">担当者（役割）</label>
                    <select name="AssigneeAndRole" class="form-select" required>
                        <option value="">担当者を選択</option>
                        @foreach(var option in assigneeOptions)
                        {
                            <option value="@option">@option</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">期限 (DueDate)</label>
                    <input type="date" name="DueDate" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-plus-circle"></i> 追加
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- カンバンボード（4つの列） -->
    <div class="row flex-nowrap overflow-auto" style="min-height: 60vh;">
        
        <!-- ToDo 列 -->
        <div class="col-md-3 min-width-300">
            <div class="card bg-light shadow-sm h-100">
                <div class="card-header bg-secondary text-white fw-bold">
                    📋 ToDo (未着手) <span class="badge bg-light text-dark rounded-pill float-end">@todoItems.Count</span>
                </div>
                <div class="card-body p-2" style="background-color: #f4f5f7;">
                    @foreach (var item in todoItems)
                    {
                        <div class="card mb-2 shadow-sm border-0 border-start border-secondary border-4">
                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold">@item.Title</h6>
                                <p class="card-text small mb-2 text-muted">
                                    <i class="bi bi-calendar-event"></i> @item.DueDate.ToString("yyyy/MM/dd")
                                </p>
                                <div class="mb-3">
                                    <span class="badge @GetRoleBadgeColor(item.Role)">@item.Assignee (@item.Role)</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <form method="post" asp-page-handler="Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="削除">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="UpdateStatus" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="newStatus" value="InProgress" />
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            着手する <i class="bi bi-arrow-right"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- In Progress 列 -->
        <div class="col-md-3 min-width-300">
            <div class="card bg-light shadow-sm h-100">
                <div class="card-header bg-primary text-white fw-bold">
                    👨‍💻 In Progress (進行中) <span class="badge bg-light text-dark rounded-pill float-end">@inProgressItems.Count</span>
                </div>
                <div class="card-body p-2" style="background-color: #e3f2fd;">
                    @foreach (var item in inProgressItems)
                    {
                        <div class="card mb-2 shadow-sm border-0 border-start border-primary border-4">
                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold">@item.Title</h6>
                                <p class="card-text small mb-2 text-muted">
                                    <i class="bi bi-calendar-event"></i> @item.DueDate.ToString("yyyy/MM/dd")
                                </p>
                                <div class="mb-3">
                                    <span class="badge @GetRoleBadgeColor(item.Role)">@item.Assignee (@item.Role)</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <form method="post" asp-page-handler="UpdateStatus" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="newStatus" value="ToDo" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="戻す">
                                            <i class="bi bi-arrow-left"></i>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="UpdateStatus" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="newStatus" value="Review" />
                                        <button type="submit" class="btn btn-sm btn-warning text-dark">
                                            レビュー依頼 <i class="bi bi-arrow-right"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Review 列 -->
        <div class="col-md-3 min-width-300">
            <div class="card bg-light shadow-sm h-100">
                <div class="card-header bg-warning text-dark fw-bold">
                    👀 Review (確認待ち) <span class="badge bg-light text-dark rounded-pill float-end">@reviewItems.Count</span>
                </div>
                <div class="card-body p-2" style="background-color: #fff3cd;">
                    @foreach (var item in reviewItems)
                    {
                        <div class="card mb-2 shadow-sm border-0 border-start border-warning border-4">
                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold">@item.Title</h6>
                                <p class="card-text small mb-2 text-muted">
                                    <i class="bi bi-calendar-event"></i> @item.DueDate.ToString("yyyy/MM/dd")
                                </p>
                                <div class="mb-3">
                                    <span class="badge @GetRoleBadgeColor(item.Role)">@item.Assignee (@item.Role)</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <form method="post" asp-page-handler="UpdateStatus" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="newStatus" value="InProgress" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="差し戻し">
                                            <i class="bi bi-arrow-left"></i>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="UpdateStatus" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="newStatus" value="Done" />
                                        <button type="submit" class="btn btn-sm btn-success">
                                            完了(LGTM) <i class="bi bi-check2-all"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Done 列 -->
        <div class="col-md-3 min-width-300">
            <div class="card bg-light shadow-sm h-100">
                <div class="card-header bg-success text-white fw-bold">
                    🎉 Done (完了) <span class="badge bg-light text-dark rounded-pill float-end">@doneItems.Count</span>
                </div>
                <div class="card-body p-2" style="background-color: #d1e7dd;">
                    @foreach (var item in doneItems)
                    {
                        <div class="card mb-2 shadow-sm border-0 border-start border-success border-4 opacity-75">
                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold text-decoration-line-through text-muted">@item.Title</h6>
                                <p class="card-text small mb-2 text-muted">
                                    <i class="bi bi-calendar-event"></i> @item.DueDate.ToString("yyyy/MM/dd")
                                </p>
                                <div class="mb-3">
                                    <span class="badge @GetRoleBadgeColor(item.Role)">@item.Assignee (@item.Role)</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <form method="post" asp-page-handler="UpdateStatus" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="newStatus" value="Review" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="戻す">
                                            <i class="bi bi-arrow-left"></i>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="完全に削除">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .min-width-300 {
        min-width: 320px;
    }
</style>
